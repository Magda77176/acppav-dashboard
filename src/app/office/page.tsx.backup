// Stairs to mezzanine
function Stairs() {
  const steps = [];
  for (let i = 0; i < 10; i++) {
    steps.push(
      <mesh key={i} position={[-8 + i * 0.3, 0.1 + i * 0.32, 2 + i * 0.5]}>
        <boxGeometry args={[1.2, 0.2, 0.5]} />
        <meshStandardMaterial color="#34495E" />
      </mesh>
    );
  }
  
  return (
    <group>
      {steps}
      {/* Railing */}
      <mesh position={[-5.5, 1.6, 4.5]}>
        <boxGeometry args={[0.1, 1.2, 6]} />
        <meshStandardMaterial color="#34495E" />
      </mesh>
    </group>
  );
}

