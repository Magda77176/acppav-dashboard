const ZONE_POSITIONS = {
  desk: [
    [-3.5, 0, 1], [-1.5, 0, 1], [0.5, 0, 1], [2.5, 0, 1],
    [-3.5, 0, -1], [-1.5, 0, -1], [0.5, 0, -1], [2.5, 0, -1],
