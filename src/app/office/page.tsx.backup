    [-7.5, 0, -4], [-8.5, 0, -3.5]
  ],
  lounge: [
    [5, 0, -4], [6, 0, -3.5], [4, 0, -4.5], [5.5, 0, -3],
    [4.5, 0, -3.5], [6.5, 0, -4]
  ],
  gaming: [
    [0, 3.2, 4], [-1, 3.2, 4.5], [1, 3.2, 3.5], [0.5, 3.2, 5],
    [-0.5, 3.2, 3.5], [1.5, 3.2, 4.5]
  ],
  rest: [
    [-2, 3.2, 5], [-3, 3.2, 5.5], [-1, 3.2, 4.5], [-2.5, 3.2, 4.5],
    [-1.5, 3.2, 5.5], [-3.5, 3.2, 5]
  ]
};

// Agent movement hook
function useAgentMovement(homePosition: [number, number, number], zone: string) {
  const [targetPos, setTargetPos] = useState(homePosition);
  const [currentAnimation, setCurrentAnimation] = useState('Idle');
  const [isMoving, setIsMoving] = useState(false);
  const currentPos = useRef(new THREE.Vector3(...homePosition));

  useEffect(() => {
    const interval = setInterval(() => {
      const destinations = ZONE_POSITIONS[zone as keyof typeof ZONE_POSITIONS] || [homePosition];
      const goElsewhere = Math.random() < 0.3;
      
      let newTarget: [number, number, number];
      
      if (goElsewhere) {
        const otherZones = Object.keys(ZONE_POSITIONS).filter(z => z !== zone);
        const randomZone = otherZones[Math.floor(Math.random() * otherZones.length)];
        const positions = ZONE_POSITIONS[randomZone as keyof typeof ZONE_POSITIONS];
        newTarget = positions[Math.floor(Math.random() * positions.length)] as [number, number, number];
      } else {
        // Petits mouvements dans sa zone
        newTarget = [
          homePosition[0] + (Math.random() - 0.5) * 3,
          homePosition[1],
          homePosition[2] + (Math.random() - 0.5) * 3
        ];
      }
      
      setTargetPos(newTarget);
      setIsMoving(true);
      setCurrentAnimation('Walking_A');
    }, 8000 + Math.random() * 7000);
    
    return () => clearInterval(interval);
  }, [homePosition, zone]);

  const updatePosition = useCallback((delta: number) => {
    const target = new THREE.Vector3(...targetPos);
    const distance = currentPos.current.distanceTo(target);
    
    if (distance > 0.1) {
      currentPos.current.lerp(target, delta * 1.5);
      return {
        position: currentPos.current.toArray() as [number, number, number],
        rotation: [0, Math.atan2(target.x - currentPos.current.x, target.z - currentPos.current.z), 0] as [number, number, number],
        animation: 'Walking_A'
      };
    } else {
      if (isMoving) {
        setIsMoving(false);
        // Choose appropriate idle animation based on position
        if (targetPos[1] > 2) { // Mezzanine
          setCurrentAnimation(Math.random() > 0.5 ? 'Idle' : 'Cheer');
        } else { // Ground floor
          setCurrentAnimation(zone === 'desk' ? 'Sit_Chair_Idle' : 'Idle');
        }
      }
      return {
        position: currentPos.current.toArray() as [number, number, number],
        rotation: [0, 0, 0] as [number, number, number],
        animation: currentAnimation
      };
    }
  }, [targetPos, isMoving, zone, currentAnimation]);

  return { updatePosition };
}

// Floor component - concrete with subtle lines
function Floor() {
  const floorTexture = useMemo(() => {
    const canvas = document.createElement('canvas');
    canvas.width = 512;
    canvas.height = 512;
    const ctx = canvas.getContext('2d')!;
    
    // Base concrete color
    ctx.fillStyle = '#B8B8B0';
    ctx.fillRect(0, 0, 512, 512);
    
    // Subtle lines
    ctx.strokeStyle = '#A8A8A0';
    ctx.lineWidth = 1;
    for (let i = 0; i < 512; i += 64) {
      ctx.beginPath();
      ctx.moveTo(i, 0);
      ctx.lineTo(i, 512);
      ctx.stroke();
      
      ctx.beginPath();
      ctx.moveTo(0, i);
      ctx.lineTo(512, i);
      ctx.stroke();
    }
    
    const texture = new THREE.CanvasTexture(canvas);
    texture.wrapS = texture.wrapT = THREE.RepeatWrapping;
    texture.repeat.set(6, 6);
    return texture;
  }, []);

  return (
    <mesh rotation={[-Math.PI / 2, 0, 0]} position={[0, 0, 0]}>
      <planeGeometry args={[30, 25]} />
      <meshStandardMaterial map={floorTexture} roughness={0.8} />
    </mesh>
  );
}

// Mezzanine floor
function MezzanineFloor() {
  const parquetTexture = useMemo(() => {
    const canvas = document.createElement('canvas');
    canvas.width = 512;
    canvas.height = 512;
    const ctx = canvas.getContext('2d')!;
    
    // Base parquet color
    ctx.fillStyle = '#C4A47A';
    ctx.fillRect(0, 0, 512, 512);
    
    // Parquet planks
    const plankWidth = 128;
    const plankHeight = 24;
    
    for (let y = 0; y < 512; y += plankHeight) {
      for (let x = 0; x < 512; x += plankWidth) {
        const variation = (Math.random() - 0.5) * 0.2;
        const r = Math.floor(0xC4 * (1 + variation));
        const g = Math.floor(0xA4 * (1 + variation));
        const b = Math.floor(0x7A * (1 + variation));
        ctx.fillStyle = `rgb(${r}, ${g}, ${b})`;
        ctx.fillRect(x, y, plankWidth, plankHeight);
        
        // Plank borders
        ctx.strokeStyle = '#A68B5B';
        ctx.lineWidth = 1;
        ctx.strokeRect(x, y, plankWidth, plankHeight);
      }
    }
    
    const texture = new THREE.CanvasTexture(canvas);
    texture.wrapS = texture.wrapT = THREE.RepeatWrapping;
    texture.repeat.set(4, 4);
    return texture;
  }, []);

  return (
    <mesh rotation={[-Math.PI / 2, 0, 0]} position={[0, 3.2, 3]}>
      <planeGeometry args={[12, 8]} />
      <meshStandardMaterial map={parquetTexture} roughness={0.7} />
    </mesh>
  );
}

// Brick wall texture
function createBrickTexture() {
  const canvas = document.createElement('canvas');
  canvas.width = 512;
  canvas.height = 512;
  const ctx = canvas.getContext('2d')!;
  
  // Base brick color
  ctx.fillStyle = '#8B4513';
  ctx.fillRect(0, 0, 512, 512);
  
  const brickWidth = 64;
  const brickHeight = 32;
  
  for (let y = 0; y < 512; y += brickHeight) {
    const offsetX = (y / brickHeight) % 2 === 0 ? 0 : brickWidth / 2;
    for (let x = -brickWidth; x < 512 + brickWidth; x += brickWidth) {
      const actualX = x + offsetX;
      if (actualX < 0 || actualX + brickWidth > 512) continue;
      
      const variation = (Math.random() - 0.5) * 0.3;
      const r = Math.floor(0x8B * (1 + variation));
      const g = Math.floor(0x45 * (1 + variation));
      const b = Math.floor(0x13 * (1 + variation));
      ctx.fillStyle = `rgb(${r}, ${g}, ${b})`;
      ctx.fillRect(actualX, y, brickWidth, brickHeight);
      
      // Mortar joints
      ctx.strokeStyle = '#6B3410';
      ctx.lineWidth = 2;
      ctx.strokeRect(actualX, y, brickWidth, brickHeight);
    }
  }
  
  const texture = new THREE.CanvasTexture(canvas);
  texture.wrapS = texture.wrapT = THREE.RepeatWrapping;
  texture.repeat.set(4, 6);
  return texture;
}

